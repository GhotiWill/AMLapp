<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AMLapp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="AMLapp.TakeTestPageView"
             x:DataType="vm:TakeTestPageViewModel">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="10">
      <TextBlock Text="{Binding TestName}" FontSize="26" FontWeight="Bold"/>

      <ItemsControl ItemsSource="{Binding Questions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:TestQuestionItem">
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,4">
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding QuestionText}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <ComboBox ItemsSource="{Binding Answers}" SelectedItem="{Binding SelectedAnswer}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:TestAnswerItem">
                      <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Завершить тест" Command="{Binding SubmitTestCommand}"/>
        <Button Content="Назад" Command="{Binding BackCommand}"/>
      </StackPanel>

      <TextBlock Text="{Binding SuccessMessage}" Foreground="Green"/>
      <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
