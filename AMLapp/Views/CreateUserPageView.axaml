<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AMLapp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="AMLapp.CreateUserPageView"
             x:DataType="vm:CreateUserPageViewModel">
  <Grid Margin="20" ColumnDefinitions="240,*" ColumnSpacing="16">
    <Border Grid.Column="0" Background="#F4F6FB" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="10" Padding="14">
      <StackPanel Spacing="10">
        <TextBlock Text="Навигация" FontSize="20" FontWeight="Bold"/>
        <Button Content="Статистика" Command="{Binding GoToStatisticsCommand}" HorizontalAlignment="Stretch"/>
        <Button Content="Создать пользователя" IsEnabled="False" HorizontalAlignment="Stretch"/>
        <Button Content="Создать тест" Command="{Binding GoToCreateTestCommand}" HorizontalAlignment="Stretch"/>
        <Button Content="Назначить тест" Command="{Binding GoToAssignTestCommand}" HorizontalAlignment="Stretch"/>
        <Button Content="Выйти" Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch"/>
      </StackPanel>
    </Border>

    <Border Grid.Column="1" BorderBrush="#D8DEE9" BorderThickness="1" Background="#FAFBFE" CornerRadius="10" Padding="16">
      <StackPanel Spacing="10" Width="420">
      <TextBlock Text="Создание пользователя" FontSize="26" FontWeight="Bold"/>

      <TextBlock Text="Логин"/>
      <TextBox Text="{Binding Login}" Watermark="Введите логин"/>

      <TextBlock Text="Пароль"/>
      <TextBox Text="{Binding Password}" PasswordChar="*" Watermark="Введите пароль"/>

      <CheckBox Content="Администратор" IsChecked="{Binding IsAdmin}"/>

      <Button Content="Создать пользователя" Command="{Binding CreateUserCommand}" Width="200"/>

      <TextBlock Text="{Binding SuccessMessage}" Foreground="Green"/>
      <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"/>
    </StackPanel>
    </Border>
  </Grid>
</UserControl>
