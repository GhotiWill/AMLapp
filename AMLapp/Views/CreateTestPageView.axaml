<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AMLapp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="900"
             x:Class="AMLapp.CreateTestPageView"
             x:DataType="vm:CreateTestPageViewModel">
  <Grid Margin="16" ColumnDefinitions="220,*">
    <StackPanel Grid.Column="0" Spacing="8">
      <TextBlock Text="Навигация" FontSize="20" FontWeight="Bold"/>
      <Button Content="Статистика" Command="{Binding GoToStatisticsCommand}"/>
      <Button Content="Создать пользователя" Command="{Binding GoToCreateUserCommand}"/>
      <Button Content="Создать тест" IsEnabled="False"/>
      <Button Content="Назначить тест" Command="{Binding GoToAssignTestCommand}"/>
      <Button Content="Выйти" Command="{Binding LogoutCommand}"/>
    </StackPanel>

    <ScrollViewer Grid.Column="1">
      <StackPanel Spacing="10" Width="700">
        <TextBlock Text="Создание нового теста" FontSize="24" FontWeight="Bold"/>

        <TextBlock Text="Название теста"/>
        <TextBox Text="{Binding Name}" Watermark="Введите название"/>

        <TextBlock Text="Описание"/>
        <TextBox Text="{Binding Description}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" Watermark="Введите описание"/>

        <Border BorderThickness="1" BorderBrush="LightGray" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Добавление вопросов" FontSize="18" FontWeight="SemiBold"/>
            <TextBox Text="{Binding NewQuestionText}" Watermark="Текст вопроса"/>
            <Button Content="Добавить вопрос" Command="{Binding AddQuestionCommand}" Width="160"/>
          </StackPanel>
        </Border>

        <Border BorderThickness="1" BorderBrush="LightGray" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Добавление ответа к выбранному вопросу" FontSize="18" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Questions}" SelectedItem="{Binding SelectedQuestion}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Text}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox Text="{Binding NewAnswerText}" Watermark="Текст ответа"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Балл:" VerticalAlignment="Center"/>
              <NumericUpDown Width="100" Minimum="0" Maximum="100" Value="{Binding NewAnswerScore}"/>
            </StackPanel>
            <Button Content="Добавить ответ" Command="{Binding AddAnswerCommand}" Width="160"/>
          </StackPanel>
        </Border>

        <TextBlock Text="Предпросмотр структуры нового теста" FontSize="18" FontWeight="SemiBold"/>
        <ItemsControl ItemsSource="{Binding Questions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,4">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Text}" FontWeight="SemiBold"/>
                  <ItemsControl ItemsSource="{Binding Answers}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Display, StringFormat='• {0}'}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="Создать тест" Command="{Binding CreateTestCommand}" Width="180"/>

        <TextBlock Text="{Binding SuccessMessage}" Foreground="Green"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"/>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
